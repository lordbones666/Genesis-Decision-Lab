{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RegimeAlgorithmConfig",
  "type": "object",
  "required": ["version", "regime_cap", "weekly_signal_weights", "question_adjustments"],
  "properties": {
    "version": {"type": "string"},
    "regime_cap": {"type": "number", "minimum": 0.0},
    "weekly_signal_weights": {"type": "object", "additionalProperties": {"type": "number"}},
    "question_adjustments": {"type": "object", "additionalProperties": {"type": "number"}}
  }
}
