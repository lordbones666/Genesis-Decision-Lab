{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LogoddsAlgorithmConfig",
  "type": "object",
  "required": ["version", "eta", "cap", "saturation", "cooldown_hours"],
  "properties": {
    "version": {"type": "string"},
    "eta": {"type": "number", "exclusiveMinimum": 0.0, "maximum": 1.0},
    "cap": {"type": "number", "exclusiveMinimum": 0.0},
    "saturation": {"type": "number", "exclusiveMinimum": 0.0},
    "cooldown_hours": {"type": "number", "minimum": 0.0}
  }
}
