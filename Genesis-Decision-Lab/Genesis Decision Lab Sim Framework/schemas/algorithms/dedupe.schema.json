{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DedupeAlgorithmConfig",
  "type": "object",
  "required": ["version", "c_max", "tau_hours", "fingerprint_version"],
  "properties": {
    "version": {"type": "string"},
    "c_max": {"type": "number", "exclusiveMinimum": 0.0},
    "tau_hours": {"type": "number", "minimum": 0.0},
    "fingerprint_version": {"type": "string"}
  }
}
