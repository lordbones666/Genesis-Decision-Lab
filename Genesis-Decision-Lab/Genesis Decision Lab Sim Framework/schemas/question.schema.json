{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuestionObject",
  "type": "object",
  "required": [
    "question_id",
    "wording",
    "time_window",
    "resolution_authority",
    "resolution_method",
    "binary_criteria",
    "event_definition",
    "reference_class_key",
    "version"
  ],
  "properties": {
    "question_id": {"type": "string", "minLength": 1},
    "wording": {"type": "string", "minLength": 1},
    "time_window": {
      "type": "object",
      "required": ["opens_at", "closes_at", "timezone"],
      "properties": {
        "opens_at": {"type": "string", "format": "date-time"},
        "closes_at": {"type": "string", "format": "date-time"},
        "timezone": {"type": "string", "minLength": 1}
      }
    },
    "resolution_authority": {"type": "string", "minLength": 1},
    "resolution_method": {"type": "string", "minLength": 1},
    "event_definition": {"type": "string", "minLength": 1},
    "reference_class_key": {"type": "string", "minLength": 1},
    "binary_criteria": {
      "type": "object",
      "required": ["yes_definition", "no_definition"],
      "properties": {
        "yes_definition": {"type": "string", "minLength": 1},
        "no_definition": {"type": "string", "minLength": 1}
      }
    },
    "invalidation_conditions": {"type": "array", "items": {"type": "string"}},
    "domain": {"type": "string"},
    "horizon": {"type": "string"},
    "version": {"type": "string", "minLength": 1}
  }
}
