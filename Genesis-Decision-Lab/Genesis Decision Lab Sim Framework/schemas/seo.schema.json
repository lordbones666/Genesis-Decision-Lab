{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StructuredEvidenceObject",
  "type": "object",
  "required": [
    "event_id",
    "question_id",
    "timestamp",
    "category",
    "direction",
    "magnitude",
    "claim_type",
    "source_ids",
    "source_tier"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "question_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "direction": {
      "type": "integer",
      "enum": [
        -1,
        0,
        1
      ]
    },
    "magnitude": {
      "type": "string",
      "enum": [
        "small",
        "medium",
        "large"
      ]
    },
    "claim_type": {
      "type": "string",
      "enum": [
        "event",
        "market",
        "official",
        "correction"
      ]
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "source_tier": {
      "type": "string",
      "enum": [
        "tier_1",
        "tier_2",
        "tier_3"
      ]
    },
    "resolver_authority": {
      "type": "string"
    },
    "resolver_method": {
      "type": "string"
    },
    "correction_of_event_id": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "cluster_id": {
      "type": "string"
    },
    "cluster_key_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "key_version": {
      "type": "string"
    },
    "phi_version": {
      "type": "string"
    },
    "revision_id": {
      "type": "string"
    },
    "weight_raw": {
      "type": "number"
    },
    "weight_effective": {
      "type": "number"
    }
  }
}
