{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Decision Lab Scenario",
  "type": "object",
  "required": [
    "scenario_id",
    "label",
    "horizon_steps",
    "trigger_set",
    "linked_evidence_ids",
    "state_assumptions",
    "simulator_targets",
    "regime_assumptions",
    "confidence",
    "config_version",
    "template_version"
  ],
  "properties": {
    "scenario_id": {"type": "string"},
    "label": {"type": "string"},
    "horizon_steps": {"type": "integer", "minimum": 1},
    "trigger_set": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "linked_evidence_ids": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "state_assumptions": {"type": "object", "additionalProperties": {"type": "number"}},
    "simulator_targets": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "regime_assumptions": {"type": "object", "additionalProperties": {"type": "number"}},
    "confidence": {
      "type": "object",
      "required": ["confidence_level", "uncertainty_note"],
      "properties": {
        "confidence_level": {"type": "number", "minimum": 0, "maximum": 1},
        "uncertainty_note": {"type": "string"}
      }
    },
    "config_version": {"type": "string"},
    "template_version": {"type": "string"}
  }
}
