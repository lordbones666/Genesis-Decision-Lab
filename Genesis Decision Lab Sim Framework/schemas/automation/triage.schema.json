{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Rerun Triage Defaults",
  "type": "object",
  "required": ["version", "categories", "operator_review_fields"],
  "properties": {
    "version": {"type": "string"},
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "informational",
          "evidence_only",
          "scenario_affecting",
          "rerun_required",
          "operator_review_required"
        ]
      }
    },
    "operator_review_fields": {"type": "array", "items": {"type": "string"}}
  }
}
